# Base URL of the IPTV backend API. The MSW mocks intercept this same URL,
# so you can switch between mocks and a real backend without touching code.
VITE_API_BASE_URL=http://localhost:3000

# When "true", Mock Service Worker is started before the app renders and serves
# the whole API contract from in-memory fixtures (develop without a backend).
VITE_USE_MOCKS=true
