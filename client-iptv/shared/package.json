{
  "name": "@client-iptv/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Canonical API contract and shared TypeScript types for the IPTV web client (FND-01, issue #5).",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepare": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
