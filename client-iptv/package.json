{
  "name": "client-iptv",
  "version": "0.1.0",
  "private": true,
  "description": "Personal web IPTV client (frontend + backend + shared) built on top of the iptv-org dataset.",
  "type": "module",
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:frontend": "npm run dev --workspace @client-iptv/frontend",
    "dev:backend": "npm run dev --workspace @client-iptv/backend",
    "build": "npm run build --workspace @client-iptv/shared && npm run build --workspace @client-iptv/backend && npm run build --workspace @client-iptv/frontend",
    "build:shared": "npm run build --workspace @client-iptv/shared",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "etl": "npm run etl --workspace @client-iptv/backend",
    "seed": "npm run seed --workspace @client-iptv/backend",
    "deploy": "node script/deploy.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "npm-run-all2": "^7.0.2",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  }
}
