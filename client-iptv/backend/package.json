{
  "name": "@client-iptv/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend API for the personal IPTV web client (Fastify + TypeScript + SQLite).",
  "main": "dist/server.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && npm run copy:assets",
    "copy:assets": "node scripts/copy-assets.mjs",
    "start": "node dist/server.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "etl": "tsx src/etl/run.ts",
    "etl:download": "tsx src/etl/download.ts",
    "etl:load": "tsx src/etl/load.ts",
    "seed": "tsx src/etl/run.ts --seed",
    "setup": "npm run db:migrate && npm run seed",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@client-iptv/shared": "*",
    "@fastify/cors": "^10.0.1",
    "@fastify/sensible": "^6.0.2",
    "@iptv-org/sdk": "^1.5.0",
    "better-sqlite3": "^11.8.1",
    "fastify": "^5.2.1",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "typescript-eslint": "^8.21.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
