# ----------------------------------------------------------------------------
# client-iptv backend environment (BE-02 / issue #12)
# Copy to `.env` and adjust. All variables are optional; defaults shown below.
# ----------------------------------------------------------------------------

# Runtime environment: development | test | production
NODE_ENV=development

# HTTP server bind address and port
HOST=0.0.0.0
PORT=3001

# Allowed CORS origin (the Vite frontend dev server)
CORS_ORIGIN=http://localhost:5173

# SQLite database file path (DB_PATH is accepted as an alias)
DATABASE_PATH=./data/iptv.db

# Directory holding the raw iptv-org JSON snapshots used by the ETL
DATA_DIR=./data/raw

# Base URL of the iptv-org public API (used by the ETL via @iptv-org/sdk)
IPTV_API_BASE_URL=https://iptv-org.github.io/api

# Log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info
